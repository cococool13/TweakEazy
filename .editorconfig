root = true

[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.{bat,cmd}]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.reg]
end_of_line = crlf

[*.md]
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
end_of_line = lf
